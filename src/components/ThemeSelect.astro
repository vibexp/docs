---
/**
 * Overrides Starlight's dropdown ThemeSelect with a single icon button that
 * cycles light → dark → auto on click — matching the blog's ThemeToggle
 * (blog/src/components/ThemeToggle.tsx) for a consistent, simpler brand chrome.
 *
 * It reuses Starlight's theme machinery verbatim: the same `starlight-theme`
 * localStorage key, the `data-theme` attribute on <html>, and the global
 * `StarlightThemeProvider` (defined in ThemeProvider.astro). Only the UI is
 * swapped from a <select> to a <button>, so SSR FOUC handling and system-theme
 * reactivity behave exactly as upstream.
 */
import { Icon } from '@astrojs/starlight/components'
---

<starlight-theme-select>
  <button
    type="button"
    class="theme-toggle"
    aria-label={Astro.locals.t('themeSelect.accessibleLabel')}
  >
    <Icon name="sun" class="theme-icon theme-icon--light" />
    <Icon name="moon" class="theme-icon theme-icon--dark" />
    <Icon name="laptop" class="theme-icon theme-icon--auto" />
  </button>
</starlight-theme-select>

<script>
  // Global registered at runtime by Starlight's ThemeProvider.astro (inlined
  // before this script to avoid FOUC); declared here for the typechecker.
  declare const StarlightThemeProvider: {
    updatePickers: (theme?: string) => void
  }

  type Theme = 'auto' | 'dark' | 'light'

  /** Key in `localStorage` to store color theme preference at. */
  const storageKey = 'starlight-theme'

  /** Cycle order, mirroring the blog toggle: light → dark → auto → light. */
  const nextTheme: Record<Theme, Theme> = {
    light: 'dark',
    dark: 'auto',
    auto: 'light',
  }

  /** Coerce any JS value to a typesafe theme string (unknown → `'auto'`). */
  const parseTheme = (theme: unknown): Theme =>
    theme === 'auto' || theme === 'dark' || theme === 'light' ? theme : 'auto'

  /** Load the user's preference from `localStorage`. */
  const loadTheme = (): Theme =>
    parseTheme(
      typeof localStorage !== 'undefined' && localStorage.getItem(storageKey)
    )

  /** Store the user's preference in `localStorage`. */
  function storeTheme(theme: Theme): void {
    if (typeof localStorage !== 'undefined') {
      localStorage.setItem(
        storageKey,
        theme === 'light' || theme === 'dark' ? theme : ''
      )
    }
  }

  /** Get the preferred system color scheme. */
  const getPreferredColorScheme = (): Theme =>
    matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'

  /** Reflect the active preference on the button so the right icon shows. */
  function updateButtons(theme: Theme): void {
    document
      .querySelectorAll<HTMLElement>('starlight-theme-select .theme-toggle')
      .forEach(button => {
        button.dataset.theme = theme
      })
  }

  /** Update button UI, document theme, and local storage state. */
  function onThemeChange(theme: Theme): void {
    StarlightThemeProvider.updatePickers(theme)
    updateButtons(theme)
    document.documentElement.dataset.theme =
      theme === 'auto' ? getPreferredColorScheme() : theme
    storeTheme(theme)
  }

  // React to changes in system color scheme.
  matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
    if (loadTheme() === 'auto') onThemeChange('auto')
  })

  class StarlightThemeSelect extends HTMLElement {
    constructor() {
      super()
      onThemeChange(loadTheme())
      this.querySelector('button')?.addEventListener('click', () => {
        onThemeChange(nextTheme[loadTheme()])
      })
    }
  }
  customElements.define('starlight-theme-select', StarlightThemeSelect)
</script>

<style>
  .theme-toggle {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    padding: 0;
    border: 0;
    border-radius: var(--radius, 0.5rem);
    background: transparent;
    color: var(--sl-color-text);
    cursor: pointer;
    transition:
      background-color 0.15s ease,
      color 0.15s ease;
  }

  .theme-toggle:hover {
    background: var(--sl-color-gray-6, var(--sl-color-gray-7));
    color: var(--sl-color-white);
  }

  /* No persistent border/box on click — only show a focus ring for keyboard
     users (the dropdown's default focus box was the "weird border"). */
  .theme-toggle:focus {
    outline: none;
  }

  .theme-toggle:focus-visible {
    outline: 2px solid var(--sl-color-accent);
    outline-offset: 2px;
  }

  .theme-icon {
    width: 1.25rem;
    height: 1.25rem;
    display: none;
  }

  /* Show only the icon matching the active preference. */
  .theme-toggle[data-theme='light'] .theme-icon--light,
  .theme-toggle[data-theme='dark'] .theme-icon--dark,
  .theme-toggle[data-theme='auto'] .theme-icon--auto {
    display: block;
  }

  /* Fallback before JS sets data-theme: show the auto icon. */
  .theme-toggle:not([data-theme]) .theme-icon--auto {
    display: block;
  }
</style>
