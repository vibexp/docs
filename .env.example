# Docs site configuration. Copy to `.env` and fill in your real values.
# Everything here is OPTIONAL — left unset, the site builds with neutral
# `example.com` placeholders. All `PUBLIC_`-prefixed vars are exposed to the
# client by Astro and must be non-secret (public) values only.

# --- Site & SEO ---------------------------------------------------------------
# Canonical production origin for the docs site (no trailing slash).
PUBLIC_SITE_URL=https://docs.example.com
# Marketing/organization origin used in the JSON-LD publisher node.
PUBLIC_ORG_URL=https://example.com

# --- External / brand links (header nav + footer) -----------------------------
PUBLIC_WEBSITE_URL=https://example.com
PUBLIC_BLOG_URL=https://blog.example.com
PUBLIC_APP_URL=https://app.example.com
PUBLIC_GITHUB_URL=https://github.com/your-org
PUBLIC_GITHUB_REPO_URL=https://github.com/your-org/your-repo
PUBLIC_TWITTER_URL=https://x.com/your_handle
PUBLIC_PRIVACY_POLICY_URL=https://example.com/privacy-policy

# --- Footer brand attribution -------------------------------------------------
PUBLIC_BRAND_NAME=Your Brand
PUBLIC_BRAND_OPERATOR=Your Company
PUBLIC_BRAND_OPERATOR_URL=https://example.com

# --- Analytics (Google Tag Manager) -------------------------------------------
# Public, non-secret GTM container id (e.g. GTM-XXXXXXX). Unset = GTM disabled.
PUBLIC_GTM_ID=

# --- Error tracking (Sentry) --------------------------------------------------
# Public, client-side DSN. Unset = Sentry stays uninitialized.
PUBLIC_SENTRY_DSN=
# Build-time source-map upload. The Sentry integration is only enabled when
# ALL THREE of SENTRY_ORG, SENTRY_PROJECT, and SENTRY_AUTH_TOKEN are set.
SENTRY_ORG=
SENTRY_PROJECT=
# Secret — set only in your deploy environment, never commit a real value.
SENTRY_AUTH_TOKEN=
